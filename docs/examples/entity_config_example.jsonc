{
    "config": {
        "sensors": [ // all sensors (Influx: domain._entity_id(._field | "state"))
            "light.main_light",
            "light.main_light.brightness",
            "sun.sun",
            "sensor.main_brightness",
            "sensor.presence_desk",
            "sensor.presence_bed",
            "sensor.presence_overall",
            "sensor.time"
        ],
        "triggers": [ // which sensors trigger a prediction?
            "light.main_light",
            "sensor.presence_desk",
            "sensor.presence_bed",
            "sensor.presence_overall"
        ],
        "active_times": { // to prevent the model from predicting when it is not relevant.
            "start": "00:06:00",
            "end": "22:00:00"
        },
        "prediction": { // what the model is predicting
            "light.main_light": {
                "state": true,
                "data": {
                    "brightness": true,
                    "temperature": true
                }
            }
        },
        "state_recording_delay": 30 // how many seconds to wait before recording the entity state.
    }
}